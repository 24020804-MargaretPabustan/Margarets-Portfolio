      <p class="score-text">Grade: A (4.0 GPA)</p>
      <img src="/images/C270_scores.png" alt="C270 Score" class="score-image mb-2">
      <a href="/images/C270_scores.png" target="_blank" class="btn btn-blue">View Full Screen</a>
    </div>
  </div>

  <!-- C322 & C326 Score Card -->
  <div class="col-12 col-md-6 col-lg-4 d-flex justify-content-center">
    <div class="score-card">
      <h5 class="score-title">C322 – Cloud Data Centre & C326 – Internetworking</h5>
      <p class="score-text">Grade: Distinction</p>
      <img src="/images/C322_C326_scores.png" alt="C322 and C326 Scores" class="score-image mb-2">
      <a href="/images/C322_C326_scores.png" target="_blank" class="btn btn-blue">View Full Screen</a>
    </div>
  </div>
</div>
  </div>
</div>
