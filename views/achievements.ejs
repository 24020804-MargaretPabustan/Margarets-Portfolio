      <p class="score-text">Grade: A (4.0 GPA)</p>
      <img src="/images/C206_C237_scores.png" alt="C206 and C237 Scores" class="score-image mb-2">
      <a href="/images/C206_C237_scores.png" target="_blank" class="btn btn-blue">View Full Screen</a>
    </div>
  </div>

  <!-- C270 Score Card -->
  <div class="col-12 col-md-6 col-lg-4 d-flex justify-content-center">
