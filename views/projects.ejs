    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var fullscreenImage = document.getElementById('fullscreenImage');
        var imageModalLabel = document.getElementById('imageModalLabel');
        var imageModal = document.getElementById('imageModal');

        var imageTriggers = document.querySelectorAll('.clickable-image, .image-view-button');

        imageTriggers.forEach(function (trigger) {
          trigger.addEventListener('click', function (e) {
            e.stopPropagation(); // prevents double triggering
            var src = trigger.getAttribute('data-image-src');
            var alt = trigger.getAttribute('data-image-alt');
            if (src && fullscreenImage.src !== window.location.origin + src) {
              fullscreenImage.src = src;
              fullscreenImage.alt = alt || '';
              imageModalLabel.textContent = alt || '';
            }
          });
        });

        // clear image on modal close
        imageModal.addEventListener('hidden.bs.modal', function () {
          fullscreenImage.src = '';
        });
      });
    </script>

