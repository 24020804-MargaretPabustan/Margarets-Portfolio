            <!-- suggestStudySession() Cards -->
            <div class="row g-4 justify-content-center mt-4">
              <!-- Method Description -->
              <div class="col-12 col-md-4">
                <div class="card h-100 shadow-sm border-secondary-subtle">
                  <div class="card-body text-center">
