                    <img src="/images/suggeststudysession.png" alt="suggestStudySession Method"
                         class="img-fluid mb-2 clickable-image"
                         data-bs-toggle="modal" data-bs-target="#imageModal"
                         data-image-src="/images/suggeststudysession.png"
