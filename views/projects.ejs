                         data-bs-toggle="modal" data-bs-target="#imageModal"
                         data-image-src="/images/prioritizetasks_output.png"
                         data-image-alt="prioritizeTasks Output">
                    <button class="btn btn-sm btn-outline-primary image-view-button"
                            data-bs-toggle="modal" data-bs-target="#imageModal"
                            data-image-src="/images/prioritizetasks_output.png"
