                <div class="card h-100 shadow-sm border-secondary-subtle">
                  <div class="card-body text-center">
                    <h6 class="card-subtitle mb-3" style="color: #0d6efd;">prioritizeTasks()</h6>
                    <img src="/images/prioritizeTasks method.png" alt="prioritizeTasks Method"
                         class="img-fluid mb-2 clickable-image"
                         data-bs-toggle="modal" data-bs-target="#imageModal"
                         data-image-src="/images/prioritizeTasks method.png"
                         data-image-alt="prioritizeTasks Method">
                    <button class="btn btn-sm btn-outline-primary image-view-button"
                            data-bs-toggle="modal" data-bs-target="#imageModal"
                            data-image-src="/images/prioritizeTasks method.png"
                            data-image-alt="prioritizeTasks Method">View Fullscreen</button>
                    <p class="mt-2"><strong>Description:</strong> <br>
                      <ol>
                        <li>Subject priority(Higher priority subjects come first)</li> 
                        <li>Task (Incomplete tasks before completed ones)</li>
                        <li>Deadline (Earlier deadlines first)</li>
                      </ol>
                    </p>
                  </div>
                </div>
              </div>

              <!-- prioritizeTasks() Test Code -->
